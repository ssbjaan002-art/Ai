<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020617"
    android:padding="24dp">

    <!-- Premium Holographic Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentTop="true"
        android:layout_marginTop="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AUROZA AI"
            android:textColor="#22d3ee"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed-light"
            android:letterSpacing="0.2"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Always Active • Continuous Ears Mode"
            android:textColor="#475569"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Response Display Area -->
    <ScrollView
        android:id="@+id/responseScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/controlLayout"
        android:layout_below="@+id/headerLayout"
        android:layout_marginVertical="32dp"
        android:fillViewport="true">

        <TextView
            android:id="@+id/responseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="How can I assist you on your device today? Just hold the mic button or ask in English, Urdu, Hindi, or Sindhi."
            android:textColor="#cbd5e1"
            android:textSize="16sp"
            android:gravity="center"
            android:lineSpacingExtra="6dp"
            android:fontFamily="sans-serif"/>
    </ScrollView>

    <!-- Footer Controls -->
    <LinearLayout
        android:id="@+id/controlLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap mic to speak"
            android:textColor="#64748b"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="16dp"/>

        <!-- Premium Cyan Mic Trigger -->
        <ImageButton
            android:id="@+id/micButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@android:color/transparent"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="#ffffff"
            android:scaleType="fitCenter"
            android:padding="16dp"/>
    </LinearLayout>

</RelativeLayout>
